@model Clean.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
}

@section styles {
    @Styles.Render("~/Content/login")
}

<div class="login-page">
    <div class="login-card">
        <h2 class="login-title">Login</h2>

        @using (Html.BeginForm("Login", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()

            <div class="login-field">
                @Html.LabelFor(m => m.Username)
                @Html.TextBoxFor(m => m.Username, new { @class = "login-input", autofocus = "autofocus", placeholder = "Enter your username" })
                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "login-error" })
            </div>

            <div class="login-field">
                @Html.LabelFor(m => m.Password)
                @Html.PasswordFor(m => m.Password, new { @class = "login-input", placeholder = "Enter your password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "login-error" })
            </div>

            @Html.ValidationSummary(true, "", new { @class = "login-error" })

            <button type="submit" class="login-button">Log in</button>
        }

        <div class="login-hint">
            <small>Available accounts: <strong>admin / admin</strong> or <strong>user / user</strong></small>
        </div>
    </div>
</div>
